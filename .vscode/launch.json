{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "NV-SMI Manager CLI",
            "type": "python",
            "request": "launch",
            "module": "nv_smi_manager.cli.commands",
            "console": "integratedTerminal",
            "args": ["status"],
            "justMyCode": true
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Tests",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v",
                "--tb=short"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
